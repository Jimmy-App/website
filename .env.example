# Sanity (public)
NEXT_PUBLIC_SANITY_PROJECT_ID=REPLACE_ME
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity (server only)
SANITY_API_VERSION=2024-02-01
SANITY_API_TOKEN=
# Shared secret for POST /api/revalidate?secret=... (must match the Sanity webhook). Generate: openssl rand -hex 32
SANITY_WEBHOOK_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Jimmy web app (login / register CTAs)
NEXT_PUBLIC_APP_URL=https://app.jimmycoach.com

# Analytics / marketing trackers — gated by cookie consent (ConsentScripts.tsx).
# Leave empty to load nothing. Set to activate once consent is granted.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
